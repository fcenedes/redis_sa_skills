      "updated": 1,
      "link": null,
      "locked": false,
      "text": "REDIS CONTEXT LAYER\n\nHASH / JSON:\ntask state, owner, files\n\nSTREAMS:\nevidence + handoffs\n\nLIST / ZSET:\nnext-action queue\n\nSEARCH:\nfind similar decisions\nand past outcomes",
      "fontSize": 17,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "REDIS CONTEXT LAYER\n\nHASH / JSON:\ntask state, owner, files\n\nSTREAMS:\nevidence + handoffs\n\nLIST / ZSET:\nnext-action queue\n\nSEARCH:\nfind similar decisions\nand past outcomes",
