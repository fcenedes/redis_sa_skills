# Local Agent Memory Server setup for Codex, Claude Code, and Claude Desktop.
REDIS_AGENT_MEMORY_VERSION=latest
REDIS_IMAGE=redis:8.6.2
REDIS_PORT=6380

AMS_API_PORT=8000
AMS_MCP_SSE_PORT=9050
AMS_MCP_HTTP_PORT=9051

REDIS_URL=redis://redis:6379
DISABLE_AUTH=true
AUTH_MODE=disabled
LONG_TERM_MEMORY=true
ENABLE_TOPIC_EXTRACTION=true
ENABLE_NER=true

# Required for embeddings and long-term memory semantic search.
OPENAI_API_KEY=
GENERATION_MODEL=gpt-4o-mini
FAST_MODEL=gpt-4o-mini
SLOW_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
REDISVL_VECTOR_DIMENSIONS=1536

# Optional direct Anthropic generation. Keep OpenAI key if using OpenAI embeddings.
ANTHROPIC_API_KEY=
# GENERATION_MODEL=claude-3-5-haiku-20241022

# Optional AWS credentials for Bedrock-backed models.
AWS_REGION_NAME=
REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

DEFAULT_MCP_USER_ID=local-user
DEFAULT_MCP_NAMESPACE=agent-memory-local
LOG_LEVEL=INFO
